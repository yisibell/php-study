# ==============================================
# 🔥 全局项目配置（你只需要改这里）
# ==============================================

# 项目源码目录（你要的 ../php8-annotation-routes）
PROJECT_PATH=../php8-annotation-routes

# 本地访问端口
NGINX_HOST_PORT=8080
MYSQL_HOST_PORT=3306

# PHP 版本
PHP_VERSION=8.3

# MySQL 配置
MYSQL_VERSION=8.0
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=api_db
MYSQL_USER=api_user
MYSQL_PASSWORD=api_pass

# 容器名称（方便识别）
CONTAINER_PREFIX=php-api
